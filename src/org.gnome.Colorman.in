#!@GJS@ -m

import Gio from 'gi://Gio';
import GLib from 'gi://GLib';
import { exit, programArgs } from 'system';

const exe = GLib.file_read_link('/proc/self/exe');
const prefix = GLib.path_get_dirname(GLib.path_get_dirname(exe));
const pkgdatadir = GLib.build_filenamev([prefix, 'share', '@PACKAGE_NAME@']);

for (const name of ['org.gnome.Colorman.src', 'org.gnome.Colorman.data']) {
  const path = GLib.build_filenamev([pkgdatadir, `${name}.gresource`]);
  Gio.resources_register(Gio.Resource.load(path));
}

globalThis.pkg = {
  initGettext() {},
  initFormat() {},
};

const { main } = await import('resource:///org/gnome/Colorman/js/main.js');
const exit_code = await main(['org.gnome.Colorman', ...programArgs]);
exit(exit_code);
